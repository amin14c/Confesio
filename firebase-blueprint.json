{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator account",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "isAdmin"]
    },
    "BannedUser": {
      "title": "Banned User",
      "description": "Registry of banned user UIDs",
      "type": "object",
      "properties": {
        "bannedAt": { "type": "number" },
        "reason": { "type": "string" },
        "bannedBy": { "type": "string" }
      },
      "required": ["bannedAt", "reason", "bannedBy"]
    },
    "User": {
      "title": "User",
      "description": "A user of the Confessio app (anonymous)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "credits": { "type": "number", "description": "Gamification points" },
        "dailyPoints": { "type": "number", "description": "Points earned today" },
        "lastPointDate": { "type": "string", "description": "Date of last point earning (YYYY-MM-DD)" },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "Earned badges" },
        "completed_sessions": { "type": "number" },
        "confessions": { "type": "number" },
        "guardian_sessions": { "type": "number" },
        "avg_rating": { "type": "number" },
        "lastSeen": { "type": "number" }
      },
      "required": ["uid", "createdAt", "credits", "dailyPoints", "lastPointDate", "badges", "completed_sessions", "confessions", "guardian_sessions", "avg_rating", "lastSeen"]
    },
    "QueueEntry": {
      "title": "QueueEntry",
      "description": "A user waiting for a match",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["confessor", "guardian"] },
        "lang": { "type": "string" },
        "joinedAt": { "type": "number" }
      },
      "required": ["uid", "role", "lang", "joinedAt"]
    },
    "Room": {
      "title": "Room",
      "description": "An active chat session between a confessor and a guardian",
      "type": "object",
      "properties": {
        "confessorId": { "type": "string" },
        "guardianId": { "type": "string" },
        "lang": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "createdAt": { "type": "number" },
        "typing": { "type": "object" }
      },
      "required": ["confessorId", "guardianId", "lang", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message within a room",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "role": { "type": "string", "enum": ["confessor", "guardian", "system"] },
        "timestamp": { "type": "number" },
        "reaction": { "type": ["string", "null"] },
        "replyToId": { "type": ["string", "null"] },
        "replyToText": { "type": ["string", "null"] },
        "isDeleted": { "type": "boolean" },
        "isEdited": { "type": "boolean" },
        "status": { "type": "string", "enum": ["sent", "read"] }
      },
      "required": ["text", "senderId", "role", "timestamp"]
    },
    "Signal": {
      "title": "Signal",
      "description": "WebRTC signaling data for audio calls",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["offer", "answer", "candidate", "end"] },
        "senderId": { "type": "string" },
        "data": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["type", "senderId", "timestamp"]
    },
    "Report": {
      "title": "Report",
      "description": "A report of abusive behavior in a room",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "reportedBy": { "type": "string" },
        "reportedRole": { "type": "string", "enum": ["confessor", "guardian"] },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "reviewed"] }
      },
      "required": ["roomId", "reportedBy", "reportedRole", "timestamp", "status"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Admin privileges registry"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/queues/{queueId}": {
      "schema": { "$ref": "#/entities/QueueEntry" },
      "description": "Users waiting in the matchmaking queue"
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Active chat rooms"
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages in a chat room"
    },
    "/rooms/{roomId}/signals/{signalId}": {
      "schema": { "$ref": "#/entities/Signal" },
      "description": "WebRTC signaling data for a specific room"
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "User reports of abusive behavior"
    }
  }
}
